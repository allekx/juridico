# App (produção: https://juridico-chi.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_OFFICE_SLUG=almeida-associados

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Novo formato (dashboard atual) ou legado:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase Auth → URL Configuration:
# Site URL: NEXT_PUBLIC_APP_URL
# Redirect URLs: https://seu-dominio.vercel.app/auth/callback

# Supabase Storage — bucket para documentos (criar como público/privado no painel)
# Nome padrão: client-documents

# Database (Prisma) — Supabase → Settings → Database
# Transaction pooler (app / Vercel, porta 6543)
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler (migrations / db:push, porta 5432)
DIRECT_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
